# RD-Agent model configuration
# Choose a chat model supported by LiteLLM / your provider.
CHAT_MODEL=glm-4.7-flash

# Embedding model example.
EMBEDDING_MODEL=Embedding-3

# Zhipu / GLM OpenAI-compatible API
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=replace_with_your_api_key

# Optional: if you use Azure OpenAI, fill these instead of the OpenAI settings above.
# AZURE_API_BASE=https://<your-resource>.openai.azure.com
# AZURE_API_VERSION=2024-xx-xx
# AZURE_API_KEY=replace_with_your_azure_api_key
# CHAT_MODEL=azure/<your-chat-deployment>
# EMBEDDING_MODEL=azure/<your-embedding-deployment>

# Optional: if you use DeepSeek directly.
# DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
# CHAT_MODEL=deepseek/deepseek-chat

# Qlib / RD-Agent runtime paths
# These folders are mounted inside the container.
# You can keep the defaults for the provided docker-compose.yml.
QLIB_HOME=/qlib
LOG_PATH=/qlib/git_ignore_folder/log
DATA_PATH=/qlib/git_ignore_folder/data
