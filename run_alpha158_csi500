#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: bash run.sh <experiment_name>" >&2
  exit 1
fi

EXP_NAME="$1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUT_ROOT="$SCRIPT_DIR/DATA/analysis_outputs"
OUT_DIR="$OUT_ROOT/$EXP_NAME"
LOG_DIR="$OUT_DIR/logs"
DOCKER_IMAGE="${DOCKER_IMAGE:-qlib-rdagent:latest}"
WORKDIR_IN_CONTAINER="/work"
QDATA_HOST_DIR="${QLIB_HOST_DATA_DIR:-$HOME/.qlib}"
QRUN_CFG="examples/benchmarks/LightGBM/workflow_config_lightgbm_Alpha158_csi500.yaml"
QRUN_LOG="$LOG_DIR/qrun.log"
OVERVIEW_LOG="$LOG_DIR/overview.log"

mkdir -p "$LOG_DIR"
rm -rf "$OUT_DIR/mlflow_run" "$OUT_DIR/overview.html" "$OUT_DIR/run_summary.txt" || true

cd "$SCRIPT_DIR"
PIPELINE_START_TS="$(date +%s)"

echo "[1/3] 启动 ${DOCKER_IMAGE} 容器环境"
echo "image=${DOCKER_IMAGE}" > "$OUT_DIR/container_info.txt"
echo "workdir=${WORKDIR_IN_CONTAINER}" >> "$OUT_DIR/container_info.txt"
echo "qlib_data_mount=${QDATA_HOST_DIR}" >> "$OUT_DIR/container_info.txt"

echo "[2/3] 在容器内执行 qrun 因子挖掘: ${QRUN_CFG}"
docker run --rm \
  -v "$SCRIPT_DIR:$WORKDIR_IN_CONTAINER" \
  -v "$QDATA_HOST_DIR:/root/.qlib" \
  -w "$WORKDIR_IN_CONTAINER" \
  "$DOCKER_IMAGE" \
  /bin/bash -lc "set -euo pipefail; qrun '$QRUN_CFG'" 2>&1 | tee "$QRUN_LOG"

echo "[3/3] 收集本次 MLflow 结果并生成 qlib overview.html"
LATEST_RUN_DIR="$(PIPELINE_START_TS="$PIPELINE_START_TS" SCRIPT_DIR="$SCRIPT_DIR" python3 - <<'PY'
import os
from pathlib import Path

start_ts = float(os.environ["PIPELINE_START_TS"])
root = Path(os.environ["SCRIPT_DIR"]) / "mlruns"
candidates = []
for p in root.glob('*/*/artifacts/pred.pkl'):
    try:
        stat = p.stat()
    except FileNotFoundError:
        continue
    candidates.append((stat.st_mtime, str(p.parents[1].resolve())))

if not candidates:
    raise SystemExit(1)

fresh = [item for item in candidates if item[0] >= start_ts - 1]
pool = fresh if fresh else candidates
print(max(pool)[1])
PY
)"

if [[ -z "$LATEST_RUN_DIR" ]]; then
  echo "No MLflow run artifact found under mlruns/." >&2
  exit 1
fi

echo "$LATEST_RUN_DIR" > "$OUT_DIR/latest_run_dir.txt"
rm -rf "$OUT_DIR/mlflow_run"
cp -R "$LATEST_RUN_DIR" "$OUT_DIR/mlflow_run"

docker run --rm \
  -v "$SCRIPT_DIR:$WORKDIR_IN_CONTAINER" \
  -v "$QDATA_HOST_DIR:/root/.qlib" \
  -w "$WORKDIR_IN_CONTAINER" \
  "$DOCKER_IMAGE" \
  /bin/bash -lc "set -euo pipefail; python scripts/generate_qlib_overview.py --run-dir '$WORKDIR_IN_CONTAINER/DATA/analysis_outputs/$EXP_NAME/mlflow_run' --output '$WORKDIR_IN_CONTAINER/DATA/analysis_outputs/$EXP_NAME/overview.html'" 2>&1 | tee "$OVERVIEW_LOG"

cat > "$OUT_DIR/run_summary.txt" <<EOF
experiment_name=$EXP_NAME
docker_image=$DOCKER_IMAGE
latest_run_dir=$LATEST_RUN_DIR
copied_run_dir=$OUT_DIR/mlflow_run
qrun_config=$QRUN_CFG
overview_html=$OUT_DIR/overview.html
qrun_log=$QRUN_LOG
overview_log=$OVERVIEW_LOG
EOF

echo "Done. Outputs saved in: $OUT_DIR"
